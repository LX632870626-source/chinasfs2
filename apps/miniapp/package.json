{
  "name": "@future-stars/miniapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:tt": "pnpm --filter @future-stars/shared build && taro build --type tt --watch",
    "build:tt": "pnpm --filter @future-stars/shared build && taro build --type tt",
    "build": "pnpm run build:tt",
    "test": "vitest run --passWithNoTests",
    "lint": "pnpm --filter @future-stars/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@future-stars/shared": "workspace:*",
    "@tarojs/components": "^4.1.0",
    "@tarojs/helper": "^4.1.0",
    "@tarojs/plugin-framework-react": "^4.1.0",
    "@tarojs/plugin-platform-tt": "^4.1.0",
    "@tarojs/react": "^4.1.0",
    "@tarojs/runtime": "^4.1.0",
    "@tarojs/taro": "^4.1.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@tarojs/cli": "^4.1.0",
    "@tarojs/webpack5-runner": "^4.1.0",
    "@types/react": "^19.1.6",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
